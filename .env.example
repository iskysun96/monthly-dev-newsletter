# GitHub Personal Access Token (repo read scope)
GH_SCRAPE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API Key for Claude summarization
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: skip Claude summarization for testing
# SKIP_SUMMARIZE=true

# Optional: override the week to scrape (ISO format)
# WEEK_OVERRIDE=2026-W09

# Optional: override the month to generate (YYYY-MM)
# MONTH_OVERRIDE=2026-02
